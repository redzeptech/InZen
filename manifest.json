{
  "manifest_version": 3,
  "name": "InZen - LinkedIn Temizleme",
  "version": "1.0.0",
  "description": "LinkedIn feed'indeki reklamları tespit eden tarayıcı eklentisi",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "InZen Dashboard"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
